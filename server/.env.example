# ---- Conexão com o PostgreSQL ----
# Local (Docker):
DATABASE_URL=postgres://gestor:gestor@localhost:5432/gestor_votos
# Produção (Neon): cole a connection string que termina com ?sslmode=require
# DATABASE_URL=postgres://USUARIO:SENHA@ep-xxx.neon.tech/neondb?sslmode=require

# Força SSL mesmo em hosts que não detectamos automaticamente (opcional)
# DATABASE_SSL=true

# Segredo para assinar os tokens de login (troque por algo aleatório em produção)
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-longo

# Porta da API (em produção o Render define automaticamente)
PORT=3001

# Origem(ns) permitida(s) do front, separadas por vírgula
# Local + Netlify: http://localhost:5173,https://seu-app.netlify.app
CORS_ORIGIN=http://localhost:5173

# ---- Inicialização automática (útil no Render, sem terminal no servidor) ----
# Aplica o schema.sql ao subir
# AUTO_MIGRATE=true
# Cria/atualiza o primeiro admin ao subir
# ADMIN_NAME=Administrador
# ADMIN_EMAIL=voce@email.com
# ADMIN_PASSWORD=umaSenhaForte
