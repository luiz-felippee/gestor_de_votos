{
  "name": "backend",
  "version": "1.0.0",
  "description": "API do Gestor de Votos (Express + Prisma + PostgreSQL)",
  "main": "server.ts",
  "scripts": {
    "dev": "ts-node server.ts",
    "build": "prisma generate && tsc",
    "postinstall": "prisma generate && node scripts/db-sync.js",
    "prestart": "npm run build",
    "start": "node --max-old-space-size=460 dist/server.js",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "migrate": "prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "otplib": "^13.4.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.2",
    "socket.io": "^4.8.1",
    "stripe": "^22.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/node-cache": "^4.1.3",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1"
  }
}
