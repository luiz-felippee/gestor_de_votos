generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilAcesso {
  admin
  coordenador
  cabo
  visualizador
}

enum StatusEleitor {
  ativo
  inativo
  pendente
}

// Cada campanha (candidato) é um "inquilino" isolado: vê só os próprios dados.
model Campanha {
  id                   String   @id @default(uuid())
  nome                 String
  slug                 String?  @unique
  ativa                Boolean  @default(true)
  foto_url             String?
  cargo_ultima_eleicao String?
  ano_ultima_eleicao   String?
  votos_ultima_eleicao Int?
  created_at           DateTime @default(now())

  // --- SaaS Multi-Contas ---
  plano                  String   @default("gratis") // gratis, basico, pro
  stripe_customer_id     String?  @unique
  stripe_subscription_id String?  @unique
  assinatura_status      String   @default("ativa") // ativa, inadimplente, cancelada
  assinatura_expira_em   DateTime?

  @@map("campanhas")
}

model CaboEleitoral {
  id             String    @id @default(uuid())
  campanha_id    String?
  nome           String
  telefone       String
  bairro_atuacao String?
  cidade         String?
  meta_eleitores Int       @default(0)
  foi_candidato  Boolean   @default(false)
  cargo_candidato String?
  ano_eleicao    String?
  votacao        Int?
  data_nascimento String?
  foto_url       String?
  created_at     DateTime  @default(now())
  eleitores      Eleitor[]
  usuarios       Usuario[]

  @@index([campanha_id])
  @@map("cabos")
}

model Eleitor {
  id            String         @id @default(uuid())
  campanha_id   String?
  nome          String
  telefone      String
  local_votacao String
  zona          Int
  secao         Int
  bairro        String
  cidade        String
  cabo_id       String?
  status           StatusEleitor  @default(ativo)
  observacoes      String?
  whatsapp_enviado Boolean        @default(false)
  data_nascimento  String?
  cpf              String?        @unique
  titulo_eleitor   String?        @unique
  lat              Float?
  lng              Float?
  created_at       DateTime       @default(now())
  // Normalizado (minúsculo, sem espaços nas pontas) p/ impedir duplicados
  nome_busca    String
  cabo          CaboEleitoral? @relation(fields: [cabo_id], references: [id], onDelete: SetNull)
  funis         EleitorFunil[]

  @@unique([nome_busca, zona, secao])
  // Índices para acelerar filtros/ordenação da planilha, dashboard e mapa
  @@index([campanha_id])
  @@index([cidade])
  @@index([bairro])
  @@index([cabo_id])
  @@index([status])
  @@index([created_at])
  @@index([nome_busca])
  @@index([telefone])
  @@map("eleitores")
}

model Usuario {
  id          String         @id @default(uuid())
  campanha_id String?
  super_admin Boolean        @default(false)
  nome        String
  email       String         @unique
  senha_hash  String
  role        PerfilAcesso   @default(visualizador)
  cabo_id     String?
  created_at  DateTime       @default(now())
  cabo        CaboEleitoral? @relation(fields: [cabo_id], references: [id], onDelete: SetNull)

  @@index([campanha_id])
  @@map("usuarios")
}

model ConfiguracaoWhatsApp {
  id               String   @id @default(uuid())
  campanha_id      String?  @unique
  modo             String   @default("nenhum") // nenhum, interno, zapi, evolution
  api_url          String?
  api_token        String?
  api_instancia_id String?

  // Funcionalidades CRM / Chatbot / IA
  msg_boas_vindas  String?
  ativar_chatbot   Boolean  @default(false)
  fluxo_chatbot    Json?    // Estrutura do menu de opções do chatbot
  usar_ia          Boolean  @default(false)
  ia_prompt        String?  @db.Text

  updated_at       DateTime @updatedAt

  @@map("configuracao_whatsapp")
}

model MensagemWhatsApp {
  id          String   @id @default(uuid())
  campanha_id String
  numero      String   // Número do contato no formato DDI+DDD+NUMERO (ex: 558199999999)
  texto       String
  is_from_me  Boolean  @default(false) // true se foi enviado pelo sistema/chatbot, false se foi recebida do eleitor
  lida        Boolean  @default(false) // Para a caixa de entrada (inbox)
  created_at  DateTime @default(now())

  @@index([campanha_id, numero])
  @@index([created_at])
  @@map("mensagens_whatsapp")
}

model Evento {
  id        String   @id @default(uuid())
  campanha_id String?
  titulo    String
  descricao String?
  data_hora DateTime
  local     String
  bairro    String?
  cidade    String?
  created_at DateTime @default(now())

  @@index([campanha_id])
  @@map("eventos")
}

model LogAuditoria {
  id           String   @id @default(uuid())
  campanha_id  String?
  usuario_id   String?
  usuario_nome String?
  acao         String // criar, editar, excluir, anonimizar
  entidade     String // eleitor, cabo, usuario
  entidade_id  String?
  detalhe      String?
  ip           String?
  created_at   DateTime @default(now())

  @@index([created_at])
  @@index([entidade])
  @@map("logs_auditoria")
}

model FunilWhatsApp {
  id          String       @id @default(uuid())
  campanha_id String
  nome        String
  gatilho     String       @default("novo_cadastro") // novo_cadastro, manual, etc.
  ativo       Boolean      @default(true)
  created_at  DateTime     @default(now())
  
  etapas      FunilEtapa[]
  eleitores   EleitorFunil[]

  @@index([campanha_id])
  @@map("funis_whatsapp")
}

model FunilEtapa {
  id                 String   @id @default(uuid())
  funil_id           String
  ordem              Int      // 1, 2, 3...
  dias_espera        Int      @default(0) // 0 = imediato, 1 = amanhã, etc.
  mensagem_texto     String   @db.Text
  mensagem_midia_url String?
  tipo_midia         String   @default("text") // text, image, video, audio
  
  funil              FunilWhatsApp @relation(fields: [funil_id], references: [id], onDelete: Cascade)
  eleitores_na_etapa EleitorFunil[]

  @@index([funil_id])
  @@map("funil_etapas")
}

model EleitorFunil {
  id               String   @id @default(uuid())
  eleitor_id       String
  funil_id         String
  etapa_atual_id   String?
  proxima_execucao DateTime?
  concluido        Boolean  @default(false)
  created_at       DateTime @default(now())

  funil            FunilWhatsApp @relation(fields: [funil_id], references: [id], onDelete: Cascade)
  etapa_atual      FunilEtapa?   @relation(fields: [etapa_atual_id], references: [id], onDelete: SetNull)
  eleitor          Eleitor       @relation(fields: [eleitor_id], references: [id], onDelete: Cascade)

  @@index([eleitor_id])
  @@index([funil_id])
  @@index([proxima_execucao])
  @@map("eleitores_funis")
}