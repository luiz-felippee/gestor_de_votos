generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilAcesso {
  admin
  coordenador
  cabo
  visualizador
}

enum StatusEleitor {
  ativo
  inativo
  pendente
}

// Cada campanha (candidato) é um "inquilino" isolado: vê só os próprios dados.
model Campanha {
  id                   String   @id @default(uuid())
  nome                 String
  slug                 String?  @unique
  ativa                Boolean  @default(true)
  foto_url             String?
  cargo_ultima_eleicao String?
  ano_ultima_eleicao   String?
  votos_ultima_eleicao Int?
  created_at           DateTime @default(now())

  // --- SaaS Multi-Contas ---
  plano                  String   @default("gratis") // gratis, basico, pro
  stripe_customer_id     String?
  stripe_subscription_id String?
  assinatura_status      String   @default("ativa") // ativa, inadimplente, cancelada
  assinatura_expira_em   DateTime?

  @@map("campanhas")
}

model CaboEleitoral {
  id             String    @id @default(uuid())
  campanha_id    String?
  nome           String
  telefone       String
  bairro_atuacao String?
  cidade         String?
  meta_eleitores Int       @default(0)
  foi_candidato  Boolean   @default(false)
  cargo_candidato String?
  ano_eleicao    String?
  votacao        Int?
  data_nascimento String?
  foto_url       String?
  created_at     DateTime  @default(now())
  deleted_at     DateTime?
  eleitores      Eleitor[]
  usuarios       Usuario[]

  @@index([campanha_id])
  @@map("cabos")
}

model Eleitor {
  id            String         @id @default(uuid())
  campanha_id   String?
  nome          String
  telefone      String
  local_votacao String
  zona          Int
  secao         Int
  bairro        String
  cidade        String
  cabo_id       String?
  status           StatusEleitor  @default(ativo)
  observacoes      String?
  data_nascimento  String?
  cpf              String?        @unique
  titulo_eleitor   String?        @unique
  lat              Float?
  lng              Float?
  created_at       DateTime       @default(now())
  deleted_at       DateTime?
  // Normalizado (minúsculo, sem espaços nas pontas) p/ impedir duplicados
  nome_busca    String
  cabo          CaboEleitoral? @relation(fields: [cabo_id], references: [id], onDelete: SetNull)

  @@unique([nome_busca, zona, secao])
  // Índices para acelerar filtros/ordenação da planilha, dashboard e mapa
  @@index([campanha_id])
  @@index([cidade])
  @@index([bairro])
  @@index([cabo_id])
  @@index([status])
  @@index([created_at])
  @@index([nome_busca])
  @@index([telefone])
  @@map("eleitores")
}

model Usuario {
  id          String         @id @default(uuid())
  campanha_id String?
  super_admin Boolean        @default(false)
  nome        String
  email       String         @unique
  senha_hash  String
  role        PerfilAcesso   @default(visualizador)
  cabo_id     String?
  created_at  DateTime       @default(now())
  deleted_at  DateTime?

  // Controle de sessão e segurança avançada
  token_version        Int     @default(0)
  two_factor_secret    String?
  two_factor_enabled   Boolean @default(false)

  // Recuperação de senha ("esqueci minha senha")
  reset_token         String?
  reset_token_expires DateTime?
  cabo        CaboEleitoral? @relation(fields: [cabo_id], references: [id], onDelete: SetNull)

  @@index([campanha_id])
  @@map("usuarios")
}

model Evento {
  id        String   @id @default(uuid())
  campanha_id String?
  titulo    String
  descricao String?
  data_hora DateTime
  local     String
  bairro    String?
  cidade    String?
  created_at DateTime @default(now())
  deleted_at DateTime?

  @@index([campanha_id])
  @@map("eventos")
}

model LogAuditoria {
  id           String   @id @default(uuid())
  campanha_id  String?
  usuario_id   String?
  usuario_nome String?
  acao         String // criar, editar, excluir, anonimizar
  entidade     String // eleitor, cabo, usuario
  entidade_id  String?
  detalhe      String?
  ip           String?
  created_at   DateTime @default(now())

  @@index([created_at])
  @@index([entidade])
  @@map("logs_auditoria")
}