# Conexão com o PostgreSQL
# Local (Docker, na raiz do projeto):
DATABASE_URL="postgres://gestor:gestor@localhost:5432/gestor_votos"
# Produção (Neon): cole a connection string com ?sslmode=require
# DATABASE_URL="postgres://USER:SENHA@ep-xxx.neon.tech/neondb?sslmode=require"

# Segredo para assinar os tokens de login (troque em produção)
JWT_SECRET="troque-por-um-valor-aleatorio-longo"

# Porta da API (em produção o Render define automaticamente)
PORT=3000

# Origem(ns) do front, separadas por vírgula
# Local + Netlify: http://localhost:5173,https://seu-app.netlify.app
CORS_ORIGIN="http://localhost:5173"

# Cria/atualiza o admin ao subir a API (deixe em branco para desativar)
ADMIN_NAME="Administrador"
ADMIN_EMAIL="voce@email.com"
ADMIN_PASSWORD="umaSenhaForte"
